{
  "description": "Work2 orchestrator hooks for deterministic workflow execution",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "^\\s*/work\\s+",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/work-orchestrator-hook.js",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PreToolUse node ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-step-workflow.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PreToolUse node ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-step-workflow.js"
          }
        ]
      },
      {
        "matcher": "mcp__atlassian__jira_get_issue",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PreToolUse node ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-step-workflow.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Skill|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PostToolUse node ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-step-workflow.js"
          }
        ]
      },
      {
        "matcher": "mcp__atlassian__jira_get_issue",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_HOOK_TYPE=PostToolUse node ${CLAUDE_PLUGIN_ROOT}/hooks/enforce-step-workflow.js"
          }
        ]
      }
    ]
  }
}
