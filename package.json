{
  "name": "work-workflow",
  "version": "3.2.0",
  "description": "Deterministic workflow orchestrator for Jira task implementation with state machine validation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/user/claude-plugin-work"
  },
  "scripts": {
    "test": "bash scripts/run-tests.sh",
    "test:enforce": "node --test scripts/workflows/lib/__tests__/enforce-step-workflow.test.js",
    "test:orchestrator": "node --test scripts/workflows/work/__tests__/work-orchestrator.test.js",
    "test:work-pr": "node --test scripts/workflows/work-pr/__tests__/work-pr.workflow.test.js",
    "bump": "node scripts/workflows/lib/scripts/bump-version.js",
    "dev:lint": "./scripts/workflows/lib/scripts/dev-check/dev-lint.sh",
    "dev:typecheck": "./scripts/workflows/lib/scripts/dev-check/dev-typecheck.sh",
    "dev:test": "./scripts/workflows/lib/scripts/dev-check/dev-test.sh",
    "dev:check": "pnpm dev:lint && pnpm dev:typecheck && pnpm dev:test",
    "dev:test:main": "./scripts/workflows/lib/scripts/dev-check/dev-test.sh --main",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "prepare": "command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath scripts/hooks || true",
    "quality": "node scripts/workflows/lib/scripts/quality/quality.js",
    "quality:changed": "node scripts/workflows/lib/scripts/quality/quality.js --changed"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "eslint": "^10.4.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jscpd": "^4.2.3"
  }
}
