# ─── Work Workflow Plugin Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Resolution order: .env → environment variables → defaults

# Jira project key (e.g., MYPROJ, DEVOPS)
JIRA_PROJECT_KEY=PROJ

# Jira instance URL (without https://)
JIRA_BASE_URL=your-org.atlassian.net

# Default assignee email for new Jira tickets
JIRA_ASSIGNEE_EMAIL=

# Repository name (used for worktree folder names)
REPO_NAME=my-project

# GitHub organization or user (for PR URLs, wiki links)
GITHUB_ORG=

# Worktrees base directory (default: $HOME/worktrees)
# WORKTREES_BASE=$HOME/worktrees

# Tasks base directory (default: $HOME/worktrees/tasks)
# TASKS_BASE=$HOME/worktrees/tasks

# Enable PR review comment polling in /follow-up-pr (default: true)
# Set to false to only monitor CI status without polling review comments
# FOLLOW_UP_PR_POLL_REVIEWS=true
