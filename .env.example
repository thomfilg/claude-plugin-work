# ─── Work Workflow Plugin Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Resolution order: .env → environment variables → defaults

# ─── Ticket Provider ────────────────────────────────────────────────────────
# Supported: jira, linear, github, none
# Auto-detected if not set (JIRA_PROJECT_KEY → jira, saved config)
# TICKET_PROVIDER=jira
# TICKET_PROJECT_KEY=PROJ

# ─── Jira Configuration ─────────────────────────────────────────────────────
# Jira project key (e.g., MYPROJ, DEVOPS). Also used as TICKET_PROJECT_KEY fallback.
JIRA_PROJECT_KEY=PROJ

# Jira instance URL (without https://)
JIRA_BASE_URL=your-org.atlassian.net

# Default assignee email for new Jira tickets
JIRA_ASSIGNEE_EMAIL=

# ─── Linear Configuration (when TICKET_PROVIDER=linear) ─────────────────────
# LINEAR_TEAM_ID=

# Repository name (used for worktree folder names)
REPO_NAME=my-project

# GitHub organization or user (for PR URLs, wiki links)
GITHUB_ORG=

# Worktrees base directory (default: $HOME/worktrees)
# WORKTREES_BASE=$HOME/worktrees

# Tasks base directory (default: $HOME/worktrees/tasks)
# TASKS_BASE=$HOME/worktrees/tasks

# ─── Git ──────────────────────────────────────────────
# Explicit base branch (e.g., dev, main, master). Auto-detected if not set.
# BASE_BRANCH=

# Enable PR review comment polling in /follow-up-pr (default: true)
# Set to false to only monitor CI status without polling review comments
# FOLLOW_UP_PR_POLL_REVIEWS=true

# Bot reviewer names for /follow-up-pr (comma-separated)
# FOLLOW_UP_PR_BOT_REVIEWERS=copilot-pull-request-reviewer,cursor-ai[bot]

# ─── Workflow Control ─────────────────────────────────────────────────────
# Enable TDD enforcement in /work workflow (default: disabled)
# WORK_TDD_ENFORCE=0

# Enable product brief generation before implementation (default: enabled)
# WORK_BRIEF_ENABLED=1

# Enable technical spec generation before implementation (default: enabled)
# WORK_SPEC_ENABLED=1

# Enable code-architect routing in /work-implement (default: disabled)
# WORK_ARCHITECT_ENABLED=0

# Enable workflow session locking (default: enabled)
# SESSION_GUARD_ENABLED=1

# ─── Bootstrap Features ──────────────────────────────────────────────────
# ENABLE_EMPTY_COMMIT=0
# ENABLE_DRAFT_PR=0
# ENABLE_SYMLINK=0
# ENABLE_RESOLVE_OUTDATED_COMMENTS=0

# ─── Web Apps (JSON array for QA testing) ─────────────────────────────────
# Example: [{"name":"my-app","defaultPort":3000,"type":"vite"}]
# WEB_APPS=

# Force single concurrency for dev checks (default: auto)
# LOW_CONCURRENCY=0

# ─── Agent Documentation Configuration ────────────────────────────────────
# Comma-separated relative paths to docs agents should read during their workflows.
# These docs take precedence over generic heuristics.
# Example: .rulesync/rules/code-quality.md,.rulesync/rules/types.md

# Docs for the code-checker agent (code review)
# READ_DOCS_ON_REVIEW=

# Docs for QA agents (qa-feature-tester, qa-api-tester)
# READ_DOCS_ON_QA=

# Docs for developer agents (nodejs-tdd, react-senior, devops)
# READ_DOCS_ON_DEV=

# Docs for E2E test writing
# READ_DOCS_ON_E2E=

# Docs for unit test writing
# READ_DOCS_ON_TEST=

# Docs for Storybook story writing
# READ_DOCS_ON_STORYBOOK=

# Docs for PR creation
# READ_DOCS_ON_PR=

# Docs for brief-writer agent (product brief generation)
# READ_DOCS_ON_BRIEF=

# Docs for spec-writer agent (technical specification)
# READ_DOCS_ON_SPEC=
